# ── Application ───────────────────────────────────────────────────
# Node environment. In Tauri production builds this defaults to "production".
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────
# SQLite database path (used by drizzle.config.ts for migrations).
# At runtime this is overridden by Tauri's app_data_dir.
DATABASE_URL=./dev.db
DB_PATH=./client-manager.db

# ── Schema versions ────────────────────────────────────────────────
# Bump APP_SCHEMA_VERSION on every schema-affecting release.
# MIN_COMPATIBLE_SCHEMA_VERSION is the oldest DB version this app can open.
APP_SCHEMA_VERSION=2
MIN_COMPATIBLE_SCHEMA_VERSION=1

# ── Logging ────────────────────────────────────────────────────────
# Directory for application log files (Rust tracing).
LOG_DIR=./logs
# Tracing-subscriber filter. Format: target=level,target=level,...
RUST_LOG=info,application=debug,backup=debug,database=debug,migration=debug,ipc=debug,ui=info
